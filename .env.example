# Task Manager Environment Configuration
# Copy this file to .env and configure for your computer

# Repository location (absolute path)
# Examples:
#   Mac: /Users/yourname/Documents/Task-Manager-Template
#   Windows: C:/Users/YourName/Documents/Task-Manager-Template
#   Linux: /home/yourname/task-manager
TASK_MANAGER_DIR=/Users/yourname/Documents/Task-Manager-Template

# Computer name/identifier (optional, for your reference)
COMPUTER_NAME=my-computer

# Note: This .env file should NOT be committed to git
# Each computer should have its own .env with the correct local path
